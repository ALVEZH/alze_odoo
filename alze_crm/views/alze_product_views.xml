<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_alze_product_template_tree" model="ir.ui.view">
        <field name="name">alze.product.template.tree</field>
        <field name="model">alze.product.template</field>
        <field name="arch" type="xml">
            <tree string="Productos">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_alze_product_template_form" model="ir.ui.view">
        <field name="name">alze.product.template.form</field>
        <field name="model">alze.product.template</field>
        <field name="arch" type="xml">
            <form string="Producto">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ej. Huevo Blanco, Huevo Rojo"/></h1>
                    </div>
                    <notebook>
                        <page string="Información General">
                            <group>
                                <field name="active"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group string="Descripción">
                                <field name="description" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Variantes">
                            <field name="variant_ids" mode="tree,form" context="{'default_template_id': active_id}">
                                <tree string="Variantes" editable="bottom">
                                    <field name="prefix"/>
                                    <field name="weight" string="Peso"/>
                                    <field name="suffix"/>
                                    <field name="code"/>
                                    <field name="quality"/>
                                    <field name="zone_id" string="Zona"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </tree>
                                <form string="Variante">
                                    <sheet>
                                        <field name="display_name" invisible="1"/>
                                        <group>
                                            <group>
                                                <field name="template_id" invisible="1"/>
                                                <field name="prefix"/>
                                                <field name="weight" string="Peso"/>
                                                <field name="suffix"/>
                                                <field name="code" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="quality"/>
                                                <field name="zone_id" string="Zona"/>
                                                <field name="active"/>
                                            </group>
                                        </group>

                                        <!-- Conversor de Peso (solo displays nuevos) -->
                                        <group string="Cálculos de Empaque">
                                            <group>
                                                <field name="pieces_per_box"/>
                                                <field name="box_weight_float" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="weight_per_piece_display" readonly="1"/>
                                                <field name="weight_12_pack_display" readonly="1"/>
                                                <field name="weight_cono_display" readonly="1"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_alze_product_variant_kanban" model="ir.ui.view">
        <field name="name">alze.product.variant.kanban</field>
        <field name="model">alze.product.variant</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" default_group_by="template_id">
                <field name="code"/>
                <field name="quality"/>
                <field name="zone_id"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="code"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <div><b>Calidad:</b>
                                    <t t-if="record.quality.raw_value == 'first'">Primera</t>
                                    <t t-else="">Segunda</t>
                                </div>
                                <div><b>Zona:</b> <field name="zone_id"/></div>
                                <div class="mt-2">
                                    <field name="active" widget="boolean_toggle"/>
                                    <label for="active" string="Disponible"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_alze_product" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">alze.product.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea un producto (ej. Huevo Blanco) y luego añade sus variantes.
            </p>
        </field>
    </record>

    <record id="action_alze_product_variant" model="ir.actions.act_window">
        <field name="name">Variantes de Productos</field>
        <field name="res_model">alze.product.variant</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <menuitem id="menu_alze_product_root"
              name="Productos"
              parent="crm.crm_menu_root"
              action="action_alze_product_variant"
              sequence="38"
              groups="sales_team.group_sale_salesman"/>
</odoo>