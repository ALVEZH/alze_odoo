<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Tree (lista) con miniatura pequeña -->
    <record id="view_alze_vehicle_tree" model="ir.ui.view">
        <field name="name">alze.driver.vehicle.tree</field>
        <field name="model">alze.driver.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehículos" editable="top">
                <field name="brand"/>
                <field name="model"/>
                <field name="plate"/>
                <field name="current_driver_id" options="{'no_create': True}"/>
                <field name="image" widget="image" options="{'size': [32, 32]}" class="oe_avatar_small"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Vista Kanban (tarjetas) -->
    <record id="view_alze_vehicle_kanban" model="ir.ui.view">
        <field name="name">alze.driver.vehicle.kanban</field>
        <field name="model">alze.driver.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="brand"/>
                <field name="model"/>
                <field name="plate"/>
                <field name="image"/>
                <field name="current_driver_id"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="plate"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <!-- Foto del vehículo, si existe -->
                                <img t-if="record.image.raw_value"
                                     t-att-src="kanban_image('alze.driver.vehicle', 'image', record.id.raw_value)"
                                     alt="Foto del vehículo"
                                     style="width: 100%; max-height: 180px; object-fit: cover; border-radius: 4px; margin-bottom: 8px;"/>
                                <div t-else="" class="bg-light d-flex align-items-center justify-content-center"
                                     style="height: 150px; border-radius: 4px; margin-bottom: 8px;">
                                    <i class="fa fa-truck text-muted fa-3x"/>
                                </div>
                                <!-- Datos del vehículo -->
                                <div><b>Marca/Modelo:</b> <field name="brand"/> <field name="model"/></div>
                                <div><b>Chofer:</b> <field name="current_driver_id"/></div>
                                <div class="mt-2">
                                    <field name="active" widget="boolean_toggle"/>
                                    <label for="active" string="Disponible"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Formulario con foto de tamaño moderado (200x200) -->
    <record id="view_alze_vehicle_form" model="ir.ui.view">
        <field name="name">alze.driver.vehicle.form</field>
        <field name="model">alze.driver.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehículo">
                <sheet>
                    <group>
                        <group>
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="plate"/>
                            <field name="current_driver_id" options="{'no_create': True}"/>
                            <field name="active"/>
                        </group>
                        <group string="Foto del Vehículo">
                            <div style="width: 200px; height: 200px; border: 1px solid #ced4da; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center; margin-top: 10px; background: #f8f9fa;">
                                <field name="image" widget="image" 
                                       options="{'size': [200, 200], 'preview_image': 'image'}" 
                                       style="width: 100%; height: 100%; object-fit: cover;"/>
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de ventana: kanban primero, luego tree y form -->
    <record id="action_alze_vehicle" model="ir.actions.act_window">
        <field name="name">Vehículos</field>
        <field name="res_model">alze.driver.vehicle</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>