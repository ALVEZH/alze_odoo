<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_driver_button" model="ir.ui.view">
        <field name="name">hr.employee.form.driver.button</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Agregar botón en la caja de botones del formulario -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_driver" type="object"
                        class="oe_stat_button" icon="fa-truck"
                        help="Asignar a este empleado como chofer">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Crear Chofer</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>