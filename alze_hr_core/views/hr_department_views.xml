<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_department_form_inherit_sede" model="ir.ui.view">
        <field name="name">hr.department.form.inherit.sede</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <!-- Colocar el campo Sede después de 'parent_id' (Departamento principal) -->
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="sede_principal_id" string="Sede" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>