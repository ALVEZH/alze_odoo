<odoo>
    <!-- Vista de formulario -->
    <record id="hr_attendance_view_form_inherit_sede" model="ir.ui.view">
        <field name="name">hr.attendance.form.inherit.sede</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <!-- Busca el campo que muestra la localización (puede ser 'location' o 'latitude'/'longitude') -->
            <field name="location" position="replace">
                <field name="sede_id" string="Localización"/>
            </field>
            <!-- Alternativamente, si quieres mantener ambos, ponlo junto al campo existente -->
        </field>
    </record>

    <!-- Vista de árbol (lista) -->
    <record id="hr_attendance_view_tree_inherit_sede" model="ir.ui.view">
        <field name="name">hr.attendance.tree.inherit.sede</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_tree"/>
        <field name="arch" type="xml">
            <field name="check_in" position="after">
                <field name="sede_id" string="Localización"/>
            </field>
        </field>
    </record>
</odoo>